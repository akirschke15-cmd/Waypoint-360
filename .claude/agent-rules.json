  "scoring_weights": {
    "keyword_match": 0.40,
    "context_signals": 0.35,
    "execution_requirements": 0.15,
    "historical_performance": 0.10
  },
  "score_tiers": {
    "primary": {
      "min": 80,
      "max": 100,
      "action": "invoke_immediately"
    },
    "secondary": {
      "min": 60,
      "max": 79,
      "action": "consider_alongside_primary"
    },
    "tertiary": {
      "min": 40,
      "max": 59,
      "action": "may_assist_specific_aspects"
    },
    "no_match": {
      "min": 0,
      "max": 39,
      "action": "skip"
    }
  },
  "collaboration_rules": {
    "multiple_primary": "all_agents_lead_with_coordination",
    "primary_with_secondary": "primary_leads_secondary_supports",
    "primary_with_tertiary": "primary_leads_tertiary_assists",
    "feedback_loop": "supporting_agents_flag_issues_to_primary"
  },
  "override_commands": {
    "manual_select": "/use <agent-name>",
    "disable_auto": "@skip <agent-name>"
  },
  "logging": {
    "enabled": true,
    "location": ".claude/logs/activation.log",
    "level": "info"
  }
}
