  "activation_strategy": {
    "description": "How skills are selected and prioritized",
    "rules": [
      "Higher priority skills are checked first",
      "Keywords trigger skill consideration",
      "File patterns trigger skill consideration",
      "Context keywords (from conversation) trigger skill consideration",
      "auto_activate: true means skill loads without explicit mention",
      "auto_activate: false means skill only loads when explicitly referenced",
      "Multiple skills can activate in the same session",
      "Skills do not conflict; they are complementary"
    ]
  },
  "context_hints": {
    "description": "Contextual clues that influence skill activation",
    "examples": {
      "testing_context": ["test failed", "coverage low", "red-green-refactor", "debug", "regression"],
