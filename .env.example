# Waypoint 360 Environment Configuration
# Copy to .env and customize for your environment

# Database (production uses PostgreSQL via docker-compose)
DATABASE_URL=sqlite+aiosqlite:////tmp/waypoint360.db

# Auth
SECRET_KEY=change-me-to-a-random-string-in-production

# AI / LangGraph (required for AI features)
ANTHROPIC_API_KEY=

# CORS (comma-separated or JSON array)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
